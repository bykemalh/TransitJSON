{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://dev.bykemalh.me/schema/transit-json/vehicles.schema.json",
    "title": "Vehicle",
    "description": "TransitJSON canlı araç konumu şeması",
    "type": "object",
    "properties": {
        "id": {
            "type": "string",
            "description": "Araç için benzersiz kimlik (ör. plaka veya araç kodu)"
        },
        "route_id": {
            "type": "string",
            "description": "Aracın bağlı olduğu hat (routes.id ile eşleşir)"
        },
        "trip_type": {
            "$ref": "common.schema.json#$defs/trip_type",
            "description": "Sefer tipi"
        },
        "lat": {
            "$ref": "common.schema.json#$defs/lat",
            "description": "Anlık enlem"
        },
        "lon": {
            "$ref": "common.schema.json#$defs/lon",
            "description": "Anlık boylam"
        },
        "bearing": {
            "type": "number",
            "minimum": 0,
            "maximum": 360,
            "description": "Aracın yönü (derece, opsiyonel)"
        },
        "speed": {
            "type": "number",
            "minimum": 0,
            "description": "Anlık hız (km/s, opsiyonel)"
        },
        "timestamp": {
            "$ref": "common.schema.json#$defs/last_updated",
            "description": "Konumun alındığı zaman (opsiyonel)"
        },
        "plate": {
            "type": "string",
            "description": "Araç plakası (opsiyonel)"
        },
        "vehicle_type": {
            "type": "string",
            "enum": ["bus", "minibus", "tram", "metro"],
            "description": "Araç tipi (opsiyonel)"
        },
        "wheelchair_accessible": {
            "type": "boolean",
            "description": "Aracın engelli/tekerlekli sandalye erişimine uygunluğu (opsiyonel)"
        },
        "last_updated": {
            "$ref": "common.schema.json#$defs/last_updated",
            "description": "Araç konum verisinin en son güncellenme tarihi (opsiyonel)"
        }
    },
    "required": ["id", "route_id", "trip_type", "lat", "lon"],
    "additionalProperties": false
}
