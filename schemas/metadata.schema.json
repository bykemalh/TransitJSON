{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://dev.bykemalh.me/schema/transit-json/metadata.schema.json",
    "title": "Metadata",
    "description": "TransitJSON veri seti sürüm ve yayıncı üst bilgileri",
    "type": "object",
    "properties": {
        "feed_publisher_name": {
            "type": "string",
            "description": "Veriyi sağlayan/yayınlayan kurum veya kişinin adı"
        },
        "feed_publisher_url": {
            "type": "string",
            "format": "uri",
            "description": "Yayıncı web sitesi"
        },
        "feed_lang": {
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Yayın dili (ISO 639-1, örn: tr)"
        },
        "feed_version": {
            "type": "string",
            "description": "Veri setinin sürümü veya yayın tarihi/saati"
        },
        "transit_json_version": {
            "type": "string",
            "description": "TransitJSON spesifikasyon/format sürümü (Örn: 1.0)",
            "default": "1.0"
        },
        "valid_from": {
            "type": "string",
            "format": "date",
            "description": "Verinin geçerli olmaya başladığı tarih (YYYY-MM-DD, opsiyonel)"
        },
        "valid_to": {
            "type": "string",
            "format": "date",
            "description": "Verinin geçerliliğinin bittiği tarih (YYYY-MM-DD, opsiyonel)"
        },
        "last_updated": {
            "$ref": "common.schema.json#$defs/last_updated",
            "description": "Veri setinin en son güncellenme tarihi"
        }
    },
    "required": [
        "feed_publisher_name",
        "feed_publisher_url",
        "feed_lang",
        "feed_version",
        "transit_json_version",
        "last_updated"
    ],
    "additionalProperties": false
}
