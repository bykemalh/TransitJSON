{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://dev.bykemalh.me/schema/transit-json/common.schema.json",
    "title": "Common",
    "description": "TransitJSON ortak tip tanımları ve paylaşılan sabitler",
    "$defs": {
        "trip_type": {
            "type": "string",
            "enum": ["outbound", "inbound", "loop"],
            "description": "Sefer tipi: gidiş (outbound), dönüş (inbound) veya ring (loop)"
        },
        "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 formatında zaman damgası (GPS okuma, olay zamanı vb.)"
        },
        "last_updated": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 formatında son güncellenme zamanı"
        },
        "lat": {
            "type": "number",
            "minimum": -90,
            "maximum": 90,
            "description": "WGS84 enlem koordinatı"
        },
        "lon": {
            "type": "number",
            "minimum": -180,
            "maximum": 180,
            "description": "WGS84 boylam koordinatı"
        },
        "time_hhmmss": {
            "type": "string",
            "pattern": "^([0-1]\\d|2[0-7]):[0-5]\\d:[0-5]\\d$",
            "description": "Saat formatı (HH:MM:SS, 00:00:00 - 27:00:00 arası, gece toleransı dahil)"
        },
        "currency_code": {
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "ISO 4217 para birimi kodu (örn: TRY, USD)"
        },
        "country_code": {
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "ISO 3166-1 alpha-2 ülke kodu"
        },
        "city_code": {
            "type": "string",
            "pattern": "^[A-Z]{3}$",
            "description": "3 haneli şehir kodu"
        },
        "hex_color": {
            "type": "string",
            "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$",
            "description": "RGB hex renk kodu (#RRGGBB veya #RGB)"
        },
        "day_type": {
            "type": "string",
            "enum": ["weekday", "saturday", "sunday"],
            "description": "Hafta içi, cumartesi veya pazar"
        }
    }
}
