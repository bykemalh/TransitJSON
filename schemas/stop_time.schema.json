{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://dev.bykemalh.me/schema/transit-json/stop_time.schema.json",
    "title": "StopTime",
    "description": "TransitJSON durak bazında varış/kalkış saatleri şeması",
    "type": "object",
    "properties": {
        "id": {
            "type": "string",
            "description": "Kayıt kimliği"
        },
        "trip_id": {
            "type": "string",
            "description": "Sefer kimliği (trips.id alanına referans)"
        },
        "stop_id": {
            "type": "string",
            "description": "Durak kimliği (stops.id alanına referans)"
        },
        "sequence": {
            "type": "integer",
            "minimum": 0,
            "description": "Durak sırası (0 = ilk durak)"
        },
        "arrival_time": {
            "$ref": "common.schema.json#$defs/time_hhmmss",
            "description": "Varış saati (opsiyonel)"
        },
        "departure_time": {
            "$ref": "common.schema.json#$defs/time_hhmmss",
            "description": "Kalkış saati (opsiyonel)"
        },
        "last_updated": {
            "$ref": "common.schema.json#$defs/last_updated",
            "description": "Kaydın en son güncellenme tarihi (opsiyonel)"
        }
    },
    "required": ["id", "trip_id", "stop_id", "sequence"],
    "additionalProperties": false
}
