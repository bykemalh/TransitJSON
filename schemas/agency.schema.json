{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://dev.bykemalh.me/schema/transit-json/agency.schema.json",
    "title": "Agency",
    "description": "TransitJSON ajans/işletmeci şeması",
    "type": "object",
    "properties": {
        "id": {
            "type": "string",
            "description": "Agency için benzersiz kimlik (Örn: burulas)"
        },
        "name": {
            "type": "string",
            "description": "Agency'nin tam adı (Örn: BURULAŞ)"
        },
        "city_code": {
            "$ref": "common.schema.json#$defs/city_code",
            "description": "Agency'nin bağlı olduğu şehir kodu (city.code alanına referans)"
        },
        "url": {
            "type": "string",
            "format": "uri",
            "description": "Agency'nin resmi web sitesi (opsiyonel)"
        },
        "timezone": {
            "type": "string",
            "description": "Agency'nin varsayılan zaman dilimi (IANA formatı, Örn: Europe/Istanbul)"
        },
        "phone": {
            "type": "string",
            "description": "Agency'nin iletişim telefon numarası (opsiyonel)"
        },
        "last_updated": {
            "$ref": "common.schema.json#$defs/last_updated",
            "description": "Kaydın en son güncellenme tarihi (opsiyonel)"
        }
    },
    "required": ["id", "name", "city_code"],
    "additionalProperties": false
}
