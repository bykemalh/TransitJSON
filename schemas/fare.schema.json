{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://dev.bykemalh.me/schema/transit-json/fare.schema.json",
    "title": "Fare",
    "description": "TransitJSON bilet ve ücretlendirme şeması",
    "type": "object",
    "properties": {
        "id": {
            "type": "string",
            "description": "Ücret/tarife için benzersiz kimlik"
        },
        "agency_id": {
            "type": "string",
            "description": "Ajans kimliği (agency.id alanına referans, opsiyonel)"
        },
        "route_id": {
            "type": "string",
            "description": "Sadece bu hata özel ücret (opsiyonel, null ise ajans/şehir geneli)"
        },
        "name": {
            "type": "string",
            "description": "Tarife adı (örn: Tam Kart, Öğrenci, İndirimli)"
        },
        "price": {
            "type": "number",
            "minimum": 0,
            "description": "Bilet/geçiş ücreti"
        },
        "currency": {
            "$ref": "common.schema.json#$defs/currency_code",
            "description": "Para birimi (ISO 4217)"
        },
        "payment_method": {
            "type": "string",
            "enum": ["card", "cash", "mobile", "token"],
            "description": "Ödeme yöntemi"
        },
        "transfers_allowed": {
            "type": "integer",
            "minimum": 0,
            "description": "İzin verilen ücretsiz/indirimli aktarma sayısı (opsiyonel)"
        },
        "transfer_duration": {
            "type": "integer",
            "minimum": 0,
            "description": "Saniye cinsinden aktarma süresi sınırı (opsiyonel)"
        },
        "last_updated": {
            "$ref": "common.schema.json#$defs/last_updated",
            "description": "Kaydın en son güncellenme tarihi (opsiyonel)"
        }
    },
    "required": ["id", "name", "price", "currency"],
    "additionalProperties": false
}
