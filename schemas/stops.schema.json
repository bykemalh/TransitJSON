{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://dev.bykemalh.me/schema/transit-json/stops.schema.json",
    "title": "Stops",
    "description": "TransitJSON durak şeması",
    "type": "object",
    "properties": {
        "id": {
            "type": "string",
            "description": "Durağa ait benzersiz kimlik"
        },
        "name": {
            "type": "string",
            "description": "Durak adı"
        },
        "lat": {
            "$ref": "common.schema.json#$defs/lat"
        },
        "lon": {
            "$ref": "common.schema.json#$defs/lon"
        },
        "route_ids": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Durağın bağlı olduğu route ID'leri (birden çok olabilir, opsiyonel)"
        },
        "description": {
            "type": "string",
            "description": "Durakla ilgili ek açıklama (opsiyonel)"
        },
        "wheelchair_accessible": {
            "type": "boolean",
            "description": "Durakta engelli/tekerlekli sandalye biniş imkanı (opsiyonel)"
        },
        "last_updated": {
            "$ref": "common.schema.json#$defs/last_updated",
            "description": "Kaydın en son güncellenme tarihi (opsiyonel)"
        }
    },
    "required": ["id", "name", "lat", "lon"],
    "additionalProperties": false
}
