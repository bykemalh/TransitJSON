{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "shape",
    "title": "Shape",
    "description": "TransitJSON shape geometrisi",
    "type": "object",
    "properties": {
        "id": {
            "type": "string",
            "description": "Shape için benzersiz kimlik"
        },
        "routeId": {
            "type": "string",
            "description": "Ait olduğu route kimliği"
        },
        "tripType": {
            "type": "string",
            "description": "Sefer tipi: outbound (gidiş), inbound (dönüş) veya loop (ring)",
            "enum": [
                "outbound",
                "inbound",
                "loop"
            ]
        },
        "points": {
            "type": "array",
            "minItems": 2,
            "description": "Shape'i oluşturan sıralı koordinat noktaları (WGS84)",
            "items": {
                "type": "object",
                "properties": {
                    "lat": {
                        "type": "number",
                        "minimum": -90,
                        "maximum": 90
                    },
                    "lon": {
                        "type": "number",
                        "minimum": -180,
                        "maximum": 180
                    }
                },
                "required": [
                    "lat",
                    "lon"
                ],
                "additionalProperties": false
            }
        },
        "lastUpdated": {
            "type": "string",
            "format": "date-time",
            "description": "Kaydın en son güncellenme tarihi (ISO 8601, opsiyonel)"
        }
    },
    "required": [
        "id",
        "routeId",
        "tripType",
        "points"
    ],
    "additionalProperties": false
}