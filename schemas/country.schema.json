{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "country",
    "title": "Country",
    "description": "A country schema TransitJSON",
    "type": "object",
    "properties": {
        "code": {
            "type": "string",
            "minLength": 2,
            "maxLength": 2
        },
        "name": {
            "type": "object",
            "properties": {
                "tr": {
                    "type": "string"
                },
                "en": {
                    "type": "string"
                }
            },
            "required": [
                "tr",
                "en"
            ]
        },
        "lastUpdated": {
            "type": "string",
            "format": "date-time",
            "description": "Kaydın en son güncellenme tarihi (ISO 8601, opsiyonel)"
        }
    },
    "required": [
        "code",
        "name"
    ],
    "additionalProperties": false
}