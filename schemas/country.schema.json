{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://dev.bykemalh.me/schema/transit-json/country.schema.json",
    "title": "Country",
    "description": "TransitJSON ülke şeması",
    "type": "object",
    "properties": {
        "code": {
            "$ref": "common.schema.json#$defs/country_code"
        },
        "name_i18n": {
            "type": "object",
            "patternProperties": {
                "^[a-z]{2}(-[A-Z]{2})?$": { "type": "string" }
            },
            "minProperties": 1,
            "description": "Çok dilli ad (ISO 639-1 dil kodları ile, örn: {\"tr\": \"Türkiye\", \"en\": \"Turkey\"})"
        },
        "last_updated": {
            "$ref": "common.schema.json#$defs/last_updated",
            "description": "Kaydın en son güncellenme tarihi (opsiyonel)"
        }
    },
    "required": ["code", "name_i18n"],
    "additionalProperties": false
}
