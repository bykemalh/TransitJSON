{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://dev.bykemalh.me/schema/transit-json/routes.schema.json",
    "title": "Routes",
    "description": "TransitJSON hat/route şeması",
    "type": "object",
    "properties": {
        "id": {
            "type": "string",
            "description": "Route için benzersiz kimlik"
        },
        "code": {
            "type": "string",
            "description": "Route'un kodu (Örn: 1, 38A)"
        },
        "agency_id": {
            "type": "string",
            "description": "Route'un ait olduğu ajansın kimliği (agency.id alanına referans)"
        },
        "short_name": {
            "type": "string",
            "description": "Route'un kısa adı"
        },
        "long_name": {
            "type": "string",
            "description": "Route'un uzun adı"
        },
        "description": {
            "type": "string",
            "description": "Route'un açıklaması (opsiyonel)"
        },
        "color": {
            "$ref": "common.schema.json#$defs/hex_color",
            "description": "Route'un rengi"
        },
        "car_type": {
            "type": "string",
            "description": "Taşıma türü",
            "enum": [
                "bus",
                "minibus",
                "trolleybus",
                "tram",
                "light_rail",
                "metro",
                "subway",
                "rail",
                "commuter_rail",
                "high_speed_rail",
                "ferry",
                "cable_car",
                "funicular",
                "gondola",
                "monorail",
                "aerial_lift"
            ]
        },
        "directions": {
            "type": "array",
            "items": {
                "$ref": "common.schema.json#$defs/trip_type"
            },
            "description": "Hattın çalıştığı yön türleri (opsiyonel)"
        },
        "sort_order": {
            "type": "integer",
            "minimum": 0,
            "description": "Kullanıcı arayüzünde hat listeleme sırası (opsiyonel)"
        },
        "status": {
            "type": "string",
            "enum": ["active", "inactive", "suspended"],
            "description": "Hattın aktiflik durumu (opsiyonel)"
        },
        "last_updated": {
            "$ref": "common.schema.json#$defs/last_updated",
            "description": "Kaydın en son güncellenme tarihi (opsiyonel)"
        }
    },
    "required": ["id", "code", "color", "car_type", "short_name", "agency_id"],
    "additionalProperties": false
}
