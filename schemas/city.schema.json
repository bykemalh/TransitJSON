{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://dev.bykemalh.me/schema/transit-json/city.schema.json",
    "title": "City",
    "description": "TransitJSON şehir şeması",
    "type": "object",
    "properties": {
        "name": { "type": "string" },
        "code": {
            "$ref": "common.schema.json#$defs/city_code"
        },
        "population": {
            "type": "integer",
            "minimum": 0,
            "description": "Şehir nüfusu (opsiyonel)"
        },
        "country_code": {
            "$ref": "common.schema.json#$defs/country_code",
            "description": "Ülke ISO kodu (country.code alanına referans)"
        },
        "timezone": {
            "type": "string",
            "description": "IANA zaman dilimi adı (Örn: Europe/Istanbul)",
            "pattern": "^[A-Za-z_\\-]+/[A-Za-z_\\-\\+0-9/]+$"
        },
        "last_updated": {
            "$ref": "common.schema.json#$defs/last_updated",
            "description": "Kaydın en son güncellenme tarihi (opsiyonel)"
        }
    },
    "required": ["name", "code", "country_code", "timezone"],
    "additionalProperties": false
}
