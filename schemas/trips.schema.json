{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://dev.bykemalh.me/schema/transit-json/trips.schema.json",
    "title": "Trips",
    "description": "TransitJSON sefer şeması",
    "type": "object",
    "properties": {
        "id": {
            "type": "string",
            "description": "Sefer için benzersiz kimlik"
        },
        "route_id": {
            "type": "string",
            "description": "Route kimliği (routes.id alanına referans)"
        },
        "trip_type": {
            "$ref": "common.schema.json#$defs/trip_type",
            "description": "Sefer tipi"
        },
        "day_type": {
            "$ref": "common.schema.json#$defs/day_type",
            "description": "Hafta içi, cumartesi veya pazar"
        },
        "departure_times": {
            "type": "array",
            "items": {
                "$ref": "common.schema.json#$defs/time_hhmmss"
            },
            "minItems": 1,
            "description": "İlk duraktan kalkış saatleri (HH:MM:SS)"
        },
        "headsign": {
            "type": "string",
            "description": "Araç tabelasında yazan yön bilgisi (opsiyonel)"
        },
        "wheelchair_accessible": {
            "type": "boolean",
            "description": "Seferin engelli/tekerlekli sandalye erişimine uygunluğu (opsiyonel)"
        },
        "last_updated": {
            "$ref": "common.schema.json#$defs/last_updated",
            "description": "Kaydın en son güncellenme tarihi (opsiyonel)"
        }
    },
    "required": ["id", "route_id", "trip_type", "day_type", "departure_times"],
    "additionalProperties": false
}
