{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TransitJSON StopTime",
  "description": "İlk durak (sequence=1) için departure_time zorunludur. Diğer tüm duraklar (son durak dahil) için opsiyoneldir.",
  "type": "object",
  "properties": {
    "trip_id": { "type": "string" },
    "stop_id": { "type": "string" },
    "sequence": { "type": "integer", "minimum": 1 },
    "departure_time": {
      "type": ["string", "null"],
      "pattern": "^[0-9]{1,2}:[0-5][0-9]:[0-5][0-9]$",
      "description": "HH:MM:SS, 24'ü aşabilir (örn. 25:30:00, gece yarısını geçen seferler için)"
    },
    "updated_at": { "type": "string", "format": "date-time" },
    "source": { "type": "string" }
  },
  "required": ["trip_id", "stop_id", "sequence", "updated_at"],
  "if": {
    "properties": { "sequence": { "const": 1 } }
  },
  "then": {
    "required": ["trip_id", "stop_id", "sequence", "departure_time", "updated_at"],
    "properties": {
      "departure_time": { "type": "string" }
    }
  },
  "else": {
    "properties": {
      "departure_time": { "type": ["string", "null"] }
    }
  },
  "additionalProperties": false
}
