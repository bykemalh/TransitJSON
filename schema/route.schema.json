{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TransitJSON Route",
  "type": "object",
  "properties": {
    "route_id": {
      "type": "string"
    },
    "agency_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "code": {
      "type": "string"
    },
    "color": {
      "type": "string",
      "pattern": "^#[0-9A-Fa-f]{6}$"
    },
    "vehicle_type": {
      "type": "string",
      "enum": [
        "bus",
        "tram",
        "metro"
      ],
      "description": "Aracın türü. bus: otobüs, tram: tramvay, metro: metro/hafif raylı."
    },
    "route_pattern": {
      "type": "string",
      "enum": [
        "round_trip",
        "loop"
      ],
      "description": "round_trip: gidiş/dönüş (direction 0/1). loop: ring hat, tek yön, başlangıç=bitiş."
    },
    "stop_mode": {
      "type": "string",
      "enum": [
        "fixed",
        "flexible"
      ],
      "description": "fixed: tüm ara duraklar tanımlı. flexible: sadece ilk/son durak tanımlı, arası serbest biniş."
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string"
    }
  },
  "required": [
    "route_id",
    "agency_id",
    "name",
    "vehicle_type",
    "route_pattern",
    "stop_mode",
    "updated_at"
  ],
  "additionalProperties": false
}